{
  "cli": {
    "version": ">= 16.13.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "gradleCommand": ":app:assembleProductionRelease"
      },
      "ios": {
        "buildConfiguration": "Release",
        "simulator": false,
        "scheme": "GMS (Production)"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
