{
  "name": "gms_fitness_application",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "androidDevelopmentDebug": "react-native run-android --mode=developmentDebug --appIdSuffix=development",
    "androidTestingDebug": "react-native run-android --mode=apptestingDebug --appIdSuffix=testing",
    "androidStagingDebug": "react-native run-android --mode=stagingDebug --appIdSuffix=staging",
    "androidProductionDebug": "react-native run-android --mode=productionDebug",
    "build:android:dev": "set ENVFILE=.env.development && eas build --platform android",
    "build:android:staging": "set ENVFILE=.env.staging && eas build --platform android",
    "build:android:prod": "set ENVFILE=.env.production && eas build --platform android",
    "update:dev": "eas update --channel development --message 'OTA update - dev'",
    "update:staging": "eas update --channel staging --message 'OTA update - staging'",
    "update:prod": "eas update --channel production --message 'OTA update - production'",
    "update:android:dev": "eas update --channel development --message \"Development update\" --platform android",
    "update:android:prod": "eas update --channel production --message \"Production update\" --platform android",
    "eas:configure": "eas update:configure",
    "iosDevDebug": "react-native run-ios --scheme=\"GMS (Dev)\"",
    "iosTestingDebug": "react-native run-ios --scheme=\"GMS (Testing)\"",
    "iosStagingDebug": "react-native run-ios --scheme=\"GMS (Staging)\"",
    "iosProdDebug": "react-native run-ios --scheme=\"GMS (Production)\"",

    "update:ios:dev": "eas update --channel development --message \"Dev update\" --platform ios",
    "update:ios:prod": "eas update --channel production --message \"Prod update\" --platform ios",

    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@d11/react-native-fast-image": "^8.9.2",
    "@hookform/resolvers": "^5.0.1",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-community/datetimepicker": "^8.3.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-documents/picker": "^10.1.3",
    "@react-native-firebase/app": "^21.14.0",
    "@react-native-firebase/auth": "^21.14.0",
    "@react-native-firebase/firestore": "^21.14.0",
